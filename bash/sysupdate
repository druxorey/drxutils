#!/bin/bash

declare -r FORMAT_SUCCESS="\e[1;32m[SUCCESS]\e[0m"
declare -r FORMAT_ERROR="\e[1;31m[ERROR]\e[0m"

declare -r CACHE_ROUTE="$HOME/.cache"
declare -r TRASH_ROUTE="$HOME/.local/share/Trash/files"
declare -r CACHE_WHITELIST=("uv" "actual_theme" "huggingface")

function drxutilsUpdate() {
	local repositoryUrl="https://github.com/druxorey/drxutils.git"
	local srcDirectory="$HOME/.cache/drxutils_src"
	local binDirectory="$HOME/.local/bin"
	local deletedFiles=""
	local changedFiles=""

	mkdir -p "$binDirectory"

	if [[ ! -d "$srcDirectory" ]]; then
		printf "Clonning drxutils repository...\n"
		git clone "$repositoryUrl" "$srcDirectory" --quiet
		cd "$srcDirectory" || return
		changedFiles=$(git ls-files)
	else
		cd "$srcDirectory" || return
		git fetch origin --quiet
		
		local branch=$(git branch --show-current)
		deletedFiles=$(git diff --name-only --diff-filter=D HEAD origin/"$branch")
		changedFiles=$(git diff --name-only --diff-filter=AM HEAD origin/"$branch")
		git reset --hard origin/"$branch" --quiet
	fi

	if [[ -n "$deletedFiles" ]]; then
		for file in $deletedFiles; do
			if [[ "$file" == bash/* ]]; then
				local scriptName="${file#bash/}"
				rm -f "$binDirectory/$scriptName"
				printf "%b Bash script removed locally: %s\n" "$FORMAT_SUCCESS" "$scriptName"
			elif [[ "$file" == */* ]]; then
				local dirName="${file%%/*}"
				rm -f "$binDirectory/$dirName"
				printf "%b Go project removed locally: %s\n" "$FORMAT_SUCCESS" "$dirName"
			fi
		done
	fi

	if [[ -d "bash" ]]; then
		for file in bash/*; do
			if [[ -f "$file" ]]; then
				local scriptName="${file#bash/}"
				cp -f "$file" "$binDirectory/$scriptName"
				chmod +x "$binDirectory/$scriptName"
			fi
		done
		printf "%b All bash scripts copied to %s\n" "$FORMAT_SUCCESS" "$binDirectory"
	fi

	if [[ -n "$changedFiles" ]]; then
		local -A goDirsToCompile

		for file in $changedFiles; do
			if [[ "$file" == */* ]]; then
				local dirName="${file%%/*}"
				if [[ "$dirName" != "bash" && -f "$dirName/go.mod" ]]; then
					goDirsToCompile["$dirName"]=1
				fi
			fi
		done

		for goDirectories in "${!goDirsToCompile[@]}"; do
			printf "Compiling Go project: %s...\n" "$goDirectories"
			(
				cd "$goDirectories" || exit
				if go build -o "$binDirectory/$goDirectories"; then
					printf "%b Installed: %s\n" "$FORMAT_SUCCESS" "$goDirectories"
				else
					printf "%b Compiling failed for: %s\n" "$FORMAT_ERROR" "$goDirectories" >&2
				fi
			)
		done
	else
		printf "%b Go projects are up to date.\n" "$FORMAT_SUCCESS"
	fi
}


function main() {
	sudo -v
	while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

	printf "\n\e[1;34mStarting pacman package update...\e[0m\n\n"
	if ! sudo pacman -Syu --noconfirm; then
		printf "%b Failed to update system packages.\n" "$FORMAT_ERROR" >&2
	fi

	printf "\n\e[1;34mStarting AUR package update...\e[0m\n\n"
	if ! yay -Sua --noconfirm; then
		printf "%b Failed to update AUR packages.\n" "$FORMAT_ERROR" >&2
	fi

	printf "\n\e[1;34mChecking for Discord updates...\e[0m\n\n"
	if grep -q "\[ALPM\] upgraded discord" /var/log/pacman.log | grep "$(date +%Y-%m-%d)"; then
		sh -c "$(curl -sS https://raw.githubusercontent.com/Vendicated/VencordInstaller/main/install.sh)"
	fi

	printf "\n\e[1;34mUpdating Yazi plugins...\e[0m\n\n"
	if ! ya pkg upgrade; then
		printf "%b Failed to update Yazi plugins.\n" "$FORMAT_ERROR" >&2
	fi

	printf "\n\e[1;34mUpdating drxutils...\e[0m\n\n"
	drxutilsUpdate

	local cacheSize=0
	cacheSize=$(du -sm "$CACHE_ROUTE" | cut -f1)
	if [ "$cacheSize" -gt 8192 ]; then
		local excludeArgs=()
		for item in "${CACHE_WHITELIST[@]}"; do
			excludeArgs+=( -not -path "$CACHE_ROUTE/$item" -not -path "$CACHE_ROUTE/$item/*" )
		done

		find "$CACHE_ROUTE" -mindepth 1 "${excludeArgs[@]}" -delete 2>/dev/null
		printf "%b Cache of size %sMB cleared (whitelist preserved).\n" "$FORMAT_SUCCESS" "$cacheSize"
	fi

	local trashSize=0
	trashSize=$(du -sm "$TRASH_ROUTE" | cut -f1)
	if [ "$trashSize" -gt 32768 ]; then
		sudo rm -rf "${TRASH_ROUTE:?}"/*
		printf "%b Trash of size %sMB cleared successfully.\n" "$FORMAT_SUCCESS" "$trashSize"
	fi

	[[ -d "$HOME/go" ]] && sudo rm -rf "$HOME/go"

	printf "%b System update completed.\n" "$FORMAT_SUCCESS"

	return 0
}

main "$@"
